name: OIC Export All Integrations (Validated)
 
on:
  workflow_dispatch:
 
jobs:
  export-integrations:
    runs-on: self-hosted
 
    env:
      SRC_OIC: poc-oic-devops-idqjvvuiw1f5-ia.integration.us-ashburn-1.ocp.oraclecloud.com
      SRC_USER: ${{ secrets.SRC_USER }}
      SRC_PASS: ${{ secrets.SRC_PASS }}
 
    steps:
      - name: Validate environment variables
        run: |
          echo "Validating environment variables..."
 
          if [ -z "$SRC_OIC" ]; then
            echo "❌ SRC_OIC is empty"
            exit 1
          fi
 
          if [ -z "$SRC_USER" ]; then
            echo "❌ SRC_USER is empty"
            exit 1
          fi
 
          if [ -z "$SRC_PASS" ]; then
            echo "❌ SRC_PASS is empty"
            exit 1
          fi
 
          echo "✅ Variables are set"
 
      - name: Install jq (if not present)
        run: |
          if ! command -v jq &> /dev/null; then
            echo "Installing jq..."
            sudo yum install -y jq || sudo apt-get install -y jq
          fi
 
      - name: Test OIC connectivity & auth
        run: |
          echo "Testing API connectivity..."
 
          HTTP_CODE=$(curl -L -s -o response.txt -w "%{http_code}" \
            -u $SRC_USER:$SRC_PASS \
            "https://$SRC_OIC/ic/api/integration/v1/integrations")
 
          echo "HTTP Status: $HTTP_CODE"
 
          if [ "$HTTP_CODE" -ne 200 ]; then
            echo "❌ Failed to connect or authenticate"
            cat response.txt
            exit 1
          fi
 
          echo "✅ Connectivity & authentication successful"
 
      - name: Fetch all integrations
        run: |
          echo "Fetching integrations list..."
 
          curl -L -s -u $SRC_USER:$SRC_PASS \
            -H "Accept: application/json" \
            "https://$SRC_OIC/ic/api/integration/v1/integrations?limit=1000" \
            -o integrations.json
 
          echo "Raw response:"
          cat integrations.json
 
      - name: Validate response structure
        run: |
          echo "Validating response..."
 
          if ! jq -e '.items' integrations.json > /dev/null; then
            echo "❌ Invalid response structure (no .items found)"
            exit 1
          fi
 
          COUNT=$(jq '.items | length' integrations.json)
 
          echo "Integration count: $COUNT"
 
          if [ "$COUNT" -eq 0 ]; then
            echo "⚠️ No integrations found in this OIC instance"
            exit 1
          fi
 
          echo "✅ Integrations found"
 
      - name: Extract integration list
        run: |
          jq -r '.items[] | "\(.code)|\(.version)"' integrations.json > list.txt
 
          echo "Integrations:"
          cat list.txt
 
      - name: Export all integrations
        run: |
          mkdir -p exports
 
          while read line; do
            echo "Exporting $line"
 
            HTTP_CODE=$(curl -L -s -o exports/$line.iar -w "%{http_code}" \
              -u $SRC_USER:$SRC_PASS \
              -H "Accept: application/octet-stream" \
              "https://$SRC_OIC/ic/api/integration/v1/integrations/$line/archive")
 
            if [ "$HTTP_CODE" -ne 200 ]; then
              echo "❌ Failed to export $line (HTTP $HTTP_CODE)"
              exit 1
            fi
 
          done < list.txt
 
      - name: Verify exported files
        run: |
          echo "Verifying exported files..."
 
          FAILED=0
 
          for file in exports/*.iar; do
            if [ ! -s "$file" ]; then
              echo "❌ Empty or failed file: $file"
              FAILED=1
            else
              echo "✅ $file"
            fi
          done
 
          if [ "$FAILED" -eq 1 ]; then
            echo "❌ One or more exports failed"
            exit 1
          fi
 
          echo "✅ All integrations exported successfully"
 
      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        with:
          name: oic-integrations
          path: exports/
